{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocMeld Category Index",
  "description": "Schema for categories.json produced by the categorize command",
  "type": "object",
  "required": ["created", "source_folder", "total_papers", "total_categories", "categories", "papers"],
  "properties": {
    "created": {
      "type": "string",
      "description": "ISO 8601 timestamp of index generation"
    },
    "source_folder": {
      "type": "string",
      "description": "Absolute path to the input folder"
    },
    "total_papers": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of papers in the index"
    },
    "total_categories": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of categories identified"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "papers", "keywords"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Human-readable category name"
          },
          "papers": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "description": "List of filenames assigned to this category"
          },
          "keywords": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Representative keywords for this category"
          }
        }
      }
    },
    "papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "category", "description", "keywords"],
        "properties": {
          "filename": {
            "type": "string",
            "minLength": 1,
            "description": "Original PDF filename"
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "description": "Assigned category name"
          },
          "description": {
            "type": "string",
            "description": "Paper-level description aggregated from gold stage"
          },
          "keywords": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Paper-level keywords"
          }
        }
      }
    }
  }
}
